# Server Configuration
PORT=3001
NODE_ENV=development

# Authentication
# Generate a secret key for signing JWTs (e.g. using `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
JWT_SECRET=your_super_secret_jwt_key_here

# Database (MongoDB)
# Local: mongodb://localhost:27017/virta
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/virta
MONGO_URI=mongodb://localhost:27017/virta

# Redis (For WebSockets & Job Queue)
# Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Frontend URL (For CORS)
# Local development
CORS_ORIGINS=http://localhost:5173
# Production (Update this when deploying frontend)
# CORS_ORIGINS=https://your-frontend-domain.vercel.app
